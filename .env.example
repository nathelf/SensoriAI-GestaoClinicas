# Copie para .env e preencha com os dados do seu projeto Supabase
# Dashboard: https://supabase.com/dashboard → seu projeto → Project Settings → API

VITE_SUPABASE_URL="https://SEU_PROJECT_REF.supabase.co"
# Use a chave "anon" (public): Project API keys → anon public (JWT longo que começa com eyJ)
VITE_SUPABASE_PUBLISHABLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
VITE_SUPABASE_PROJECT_ID="SEU_PROJECT_REF"

# Backend Python (Conversor de Documentos). Descomente e ajuste se for usar PDF↔Word.
VITE_DOCUMENT_API_URL="http://localhost:8000"
